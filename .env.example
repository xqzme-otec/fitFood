# Скопируйте в .env и при необходимости измените.

# Приложение
DEBUG=true

# База данных. По умолчанию SQLite (файл fitfood.db рядом с проектом).
# Для PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fitfood
# DATABASE_URL=sqlite:///./fitfood.db

# JWT (обязательно смените в проде!)
SECRET_KEY=CHANGE_ME_super_secret_dev_key_0123456789
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LLM: mock | openai | ollama | openrouter. По умолчанию mock (без ключей).
LLM_PROVIDER=mock
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenRouter (генерация рациона). Ключ держите только здесь, в репозиторий не коммитьте.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Сколько строк из CSV импортировать в каталог при первом запуске.
SEED_PRODUCTS_LIMIT=400

# Проверка чека по QR-коду (ФНС через proverkacheka.com).
# Без токена /receipts/scan-qr работает в мок-режиме (демо-чек).
# Получить токен: https://proverkacheka.com (личный кабинет → API).
# CHECK_URL=https://proverkacheka.com/api/v1/check/get
# CHECK_TOKEN=00000.XXXXXXXXXXXXXXXXX
